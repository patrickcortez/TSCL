<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
	  
	<PackageID>TSCL.Parser</PackageID> 
	<Version>1.1.0</Version>
	<Description>TSCL or Tezz's Coniguration Language is a simple config language that is flat in nature and nesting is handled using pointers that points to other sections instead of braces.</Description>
	<Author>Patrick Cortez</Author>
	<Tags>configurations;tscl;settings</Tags>
	  
	<RepositoryURL>https://github.com/patrickcortez/TSCL.git</RepositoryURL>
	<RepositoryType>git</RepositoryType>
	<PackageLicenseExpression>GPL-3.0-only</PackageLicenseExpression>
	<PackageReadmeFile>Readme.md</PackageReadmeFile>
	<Title>TSCL Parser</Title>
	<PackageReleaseNotes>Changes:
- Restuctured the entire library. Read,Write and  Modify is now
on TSCL.operations

- Added a tokenizer in Utilities

- Added Modify Class in operations

- Added getSectionObjects in Read Class</PackageReleaseNotes>
  </PropertyGroup>

	<ItemGroup>
		<None Include="..\Readme.md" Pack="true" PackagePath="\" />
	</ItemGroup>

</Project>
